# Copy to .env and adjust. Every value here has a working default in
# app/core/config.py -- you only need to set what you're changing.

# --- Database ---
# Prototype default is a local SQLite file (uses create_all). For Postgres,
# set DATABASE_URL and migrations run via Alembic (`alembic upgrade head`) on startup:
# DATABASE_URL=postgresql+psycopg2://faceauth:faceauth@localhost:5432/faceauth

# --- Access tokens ---
# Legacy shared tokens (used as fallback when no admin_users rows exist).
# Leave ADMIN_TOKEN empty in production once per-user admins are seeded.
ADMIN_TOKEN=dev-admin-token-change-me
APP_CLIENT_TOKENS=hr-portal:dev-hrportal-client-token-change-me

# --- JWT (RS256 by default) ---
# Production: provide PEM key paths. Without them, ephemeral RS256 keys are
# auto-generated at startup (dev only — tokens won't survive a restart).
# JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
# JWT_KID=prod-1
# JWT_ISSUER=face-auth-platform
# Legacy HS256: set JWT_SECRET to anything other than the placeholder to force HS256.
# JWT_SECRET=
JWT_TTL_SECONDS=600
# Step-up tokens (authorize one EMR field change) are very short-lived + single-use:
# STEPUP_TOKEN_TTL_SECONDS=60

# --- CORS ---
# Comma-separated allowlist of frontend origins. Empty = allow all (dev only).
# CORS_ORIGINS=https://emr.hospital.example,https://console.hospital.example

# --- Concurrency / upload limits ---
# MAX_CONCURRENT_INFERENCES=4          # 429 returned past this many in-flight inferences
# MAX_UPLOAD_SIZE_BYTES=10485760       # 10 MB total per request

# --- Step-up / lockout (spec §9.5) ---
# VERIFY_THRESHOLD_ARCFACE=0.50        # 1:1 verification cosine threshold
# LIVENESS_MAX_SCORED_FRAMES=3         # cap anti-spoof passes per verify (latency)
# MAX_FAILED_ATTEMPTS=5
# LOCKOUT_WINDOW_SECONDS=300

# --- Biometric template encryption at rest (AES-256 via Fernet; spec §13) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TEMPLATE_ENCRYPTION_KEY=

# --- PHI handling ---
# EMR writes return a signed receipt (value_hash + entry_hash), not the value.
# If the value MUST be stored (no external EMR of record), encrypt it at rest:
# ENCRYPT_PHI_AT_REST=<fernet-key>

# --- Audit retention ---
# AUDIT_RETENTION_DAYS=2555            # ~7 years (HIPAA)
# CONSUMED_TOKEN_RETENTION_HOURS=24    # reaped on startup + scheduled

# --- Enrollment integrity ---
# ENROLL_REQUIRE_LIVENESS=true         # reject enrolling a photo/screen

# --- Enrollment performance / limits ---
# ENROLL_MAX_PROCESS_FRAMES=120        # subsample the guided burst before the heavy ML path
# MAX_ENROLL_UPLOAD_SIZE_BYTES=157286400   # 150 MB ceiling for the enrollment burst

# --- Models (active by default from ./models; see models/README.md) ---
# ARCFACE_MODEL_PATH=./models/buffalo_l/w600k_r50.onnx
# ANTISPOOF_MODELS_DIR=./models/anti_spoof

# --- Identification thresholds (re-tune via spec Section 17's pilot ROC process) ---
# THRESHOLD_HIGH_ARCFACE=0.62
# THRESHOLD_LOW_ARCFACE=0.45
# THRESHOLD_HIGH_CLASSICAL=0.80
# THRESHOLD_LOW_CLASSICAL=0.55

# --- Liveness ---
# LIVENESS_FAIL_CLOSED=true            # if the trained model is missing, DENY (no heuristic fallback)
# LIVENESS_MIN_REAL_SCORE=0.55
# Heuristic fallback knobs (only used if LIVENESS_FAIL_CLOSED=false and weights absent):
# LIVENESS_REQUIRE_BLINK_OR_MOTION=true
# LIVENESS_MIN_SCORE=0.5
